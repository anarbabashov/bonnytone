# BTRadio Production Environment
# Copy to .env.production and fill in values

# Your domain (used in Nginx config)
DOMAIN=bonnytone.com

# Stream paths (relative — works on any domain)
NEXT_PUBLIC_STREAM_URL=/stream/hls/bonnytone/live.m3u8
NEXT_PUBLIC_AZURACAST_API_URL=/api/azuracast/nowplaying/bonnytone
AZURACAST_ORIGIN=http://azuracast:80
