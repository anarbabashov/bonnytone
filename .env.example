# === BTRadio Environment Configuration ===
# Copy this file to .env.local and fill in values
# The radio player works with just the "Radio Stream" section configured.

# === Radio Stream (required) ===
NEXT_PUBLIC_STREAM_URL=/stream/hls/btradio/live.m3u8
NEXT_PUBLIC_AZURACAST_API_URL=/api/azuracast/nowplaying/btradio
AZURACAST_ORIGIN=http://localhost:8000

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Auth (optional — player works without these) ===
DATABASE_URL=postgresql://postgres:password@localhost:5432/btradio
REDIS_URL=redis://localhost:6379
TOKEN_HMAC_SECRET=  # Generate with: openssl rand -base64 32
JWT_ISSUER=btradio
JWT_AUDIENCE=btradio.app
JWT_ALGORITHM=HS512

# === Email (optional — needed for registration) ===
EMAIL_PROVIDER=dev  # Use "dev" for local .mailbox, or "postmark"/"sendgrid"
POSTMARK_TOKEN=
SENDGRID_API_KEY=
EMAIL_FROM=BTRadio <no-reply@your-domain.com>
